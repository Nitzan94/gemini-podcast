{
  "name": "gemini-podcast-playground",
  "version": "0.1.0",
  "description": "Browser playground for gemini-podcast — paste your Gemini API key, paste content, generate a 2-host audio podcast.",
  "license": "MIT",
  "author": "Nitzan Bar-Ness",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun playground/index.html",
    "build": "bun build playground/index.html --outdir dist --minify",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5"
  }
}
